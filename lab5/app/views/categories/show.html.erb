<div class="row justify-content-center mt-5">
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3 border-bottom">
        <h5 class="card-title mb-0 text-secondary small text-uppercase fw-bold">Деталі категорії</h5>
      </div>

      <div class="card-body p-4">
        <p class="text-success small mb-2"><%= notice %></p>

        <div class="mb-4">
          <label class="text-muted small text-uppercase d-block mb-1">Назва</label>
          <h3 class="fw-normal text-dark"><%= @category.name %></h3>
        </div>

        <div class="d-flex gap-2 border-top pt-3">
          <%= link_to edit_category_path(@category), class: "btn btn-outline-primary btn-sm px-3" do %>
            Редагувати
          <% end %>

          <%= link_to categories_path, class: "btn btn-outline-secondary btn-sm px-3" do %>
            Назад
          <% end %>

          <div class="ms-auto">
            <%= button_to @category, method: :delete,
                          class: "btn btn-sm btn-link text-danger text-decoration-none",
                          form: { data: { turbo_confirm: "Ви впевнені, що хочете видалити цю категорію?" } } do %>
              Видалити
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>