<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h2 text-dark">Категорії</h1>
  <%= link_to "Нова категорія", new_category_path, class: "btn btn-primary shadow-sm" %>
</div>

<div class="table-responsive">
  <table class="table table-hover align-middle bg-white border shadow-sm rounded">
    <thead class="table-dark">
    <tr>
      <th>Назва</th>
      <th class="text-end">Дії</th>
    </tr>
    </thead>
    <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td class="fw-bold text-secondary"><%= category.name %></td>
        <td class="text-end">
          <div class="btn-group">
            <%= link_to "Перегляд", category, class: "btn btn-sm btn-outline-info" %>
            <%= link_to "Редагувати", edit_category_path(category), class: "btn btn-sm btn-outline-primary" %>
          </div>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>